# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# Public, client-exposed values (safe in the browser bundle):
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase anon/publishable key>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# Server-only mirrors used by SSR / server functions:
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<supabase anon/publishable key>"
SUPABASE_PROJECT_ID="<project-ref>"

# Server-only secrets — set in the deploy environment, never in the client:
# SUPABASE_SERVICE_ROLE_KEY="<service role key>"    # bypasses RLS; server only
# INTERNAL_FUNCTION_SECRET="<random long string>"   # shared secret for internal/cron edge-function calls
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_HTG_SECRET_KEY="sk_live_..."
# STRIPE_HTG_WEBHOOK_SECRET="whsec_..."
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# META_LEADS_WEBHOOK_TOKEN="<random long string>"
